+function CreateSkillModal({
+  open,
+  scopeKind,
+  targetId,
+  onClose,
+  onSaved,
+}: {
+  open: boolean;
+  scopeKind: "queen" | "colony";
+  targetId: string;
+  onClose: () => void;
+  onSaved: () => void;
+}) {
+  const [name, setName] = useState("");
+  const [description, setDescription] = useState("");
+  const [body, setBody] = useState("");
