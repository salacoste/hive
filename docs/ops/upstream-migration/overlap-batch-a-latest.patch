+            "required": required_rows,
+            "optional": optional_rows,
+            "missing": {"required": missing_required, "optional": missing_optional},
+            "summary": summary,
+            "providers": providers,
+            "checked_at": datetime.now(UTC).isoformat(),
+        }
+    )
