+    "w-7 h-7 rounded-md flex items-center justify-center bg-muted/80 flex-shrink-0";
+
+  return ReactDOM.createPortal(
+    <div
+      ref={ref}
+      style={{ position: "fixed", top: pos.top, left: pos.left, zIndex: 9999 }}
