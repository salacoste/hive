{
  "coder-tools": {
    "transport": "stdio",
    "command": "uv",
    "args": ["run", "python", "coder_tools_server.py", "--stdio"],
    "cwd": "../../../../tools",
    "description": "Unsandboxed file system tools for code generation and validation"
  },
  "hive-tools": {
    "transport": "stdio",
    "command": "uv",
    "args": ["run", "python", "mcp_server.py", "--stdio"],
    "cwd": "../../../../tools",
    "description": "General integration tools: web, GitHub, Telegram, Google, Redis/Postgres"
  },
  "gcu-tools": {
    "transport": "stdio",
    "command": "uv",
    "args": ["run", "python", "-m", "gcu.server", "--stdio"],
    "cwd": "../../../../tools",
    "description": "Browser automation tools"
  },
  "files-tools": {
    "transport": "stdio",
    "command": "uv",
    "args": ["run", "python", "files_server.py", "--stdio"],
    "cwd": "../../../../tools",
    "allow_zero_tools": true,
    "tools": ["read_file", "write_file", "edit_file", "list_directory", "search_files", "run_command"],
    "description": "Focused file operations tools"
  }
}
