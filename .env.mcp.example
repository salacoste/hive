# MCP tools credentials template for local docker-compose setup.
# Copy needed entries to your .env and fill values.
#
# NOTE:
# - docker-compose.yml now uses `env_file: .env`, so keys in .env are available
#   inside the hive-core container and MCP tools.
# - Keep real secrets only in .env (ignored by git), not in this file.

# Search / research
BRAVE_SEARCH_API_KEY=
EXA_API_KEY=
SERPAPI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Dev / collaboration
GITHUB_TOKEN=
SLACK_BOT_TOKEN=
NOTION_API_TOKEN=
LINEAR_API_KEY=

# Messaging / notifications
RESEND_API_KEY=
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# Google Workspace (Docs / Sheets / Gmail / Calendar)
# OAuth access token used by google_* tools in this repo.
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Default redirect for local manual flow (can be changed)
GOOGLE_REDIRECT_URI=http://localhost:8788/google/oauth/callback
# Space-separated OAuth scopes used by helper scripts
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/documents https://www.googleapis.com/auth/spreadsheets https://www.googleapis.com/auth/drive.file https://www.googleapis.com/auth/gmail.modify https://www.googleapis.com/auth/calendar
# Optional: Google token health thresholds (used by scripts/mcp_health_summary.py)
HIVE_GOOGLE_TOKEN_WARN_TTL_SECONDS=900
HIVE_GOOGLE_TOKEN_CRITICAL_TTL_SECONDS=120
# Optional: refresher alerting to Telegram when refresh fails consecutively
GOOGLE_REFRESH_ALERT_ENABLED=1
GOOGLE_REFRESH_ALERT_FAILURE_THRESHOLD=3
GOOGLE_REFRESH_ALERT_COOLDOWN_SECONDS=3600
# Comma-separated chat ids for refresher alerts (example: "123456789,987654321")
GOOGLE_REFRESH_ALERT_CHAT_IDS=
# Default Telegram chat id for smoke tests / alert fallback in containers.
HIVE_TELEGRAM_TEST_CHAT_ID=188207447
# Optional: scheduled Google canary defaults
HIVE_GOOGLE_CANARY_CRON_EXPR=*/30 * * * *
HIVE_GOOGLE_CANARY_INTERVAL_SECONDS=1800
HIVE_GOOGLE_CANARY_DOTENV=.env
HIVE_GOOGLE_CANARY_ARTIFACT_DIR=docs/ops/google-canary
HIVE_GOOGLE_CANARY_WRITE_MODE=false

# Optional Google services
GOOGLE_MAPS_API_KEY=
GOOGLE_SEARCH_CONSOLE_TOKEN=
# Path to GA service account json (host path mounted into container if needed)
GOOGLE_APPLICATION_CREDENTIALS=

# Data stores
# For local docker-compose defaults:
#   DATABASE_URL=postgresql://hive:hive@postgres:5432/hive
#   REDIS_URL=redis://redis:6379/0
DATABASE_URL=
REDIS_URL=
POSTGRES_USER=hive
POSTGRES_PASSWORD=hive
POSTGRES_DB=hive

# Optional common integrations
HUBSPOT_ACCESS_TOKEN=
AIRTABLE_PAT=
CONFLUENCE_DOMAIN=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
