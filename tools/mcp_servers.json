{
  "hive-tools": {
    "transport": "stdio",
    "command": "uv",
    "args": ["run", "python", "mcp_server.py", "--stdio"],
    "cwd": ".",
    "description": "Hive tools MCP server providing web_search, web_scrape, github, telegram, google, redis, postgres and more"
  },
  "gcu-tools": {
    "transport": "stdio",
    "command": "uv",
    "args": ["run", "python", "-m", "gcu.server", "--stdio"],
    "cwd": ".",
    "description": "GCU browser automation tools"
  },
  "files-tools": {
    "transport": "stdio",
    "command": "uv",
    "args": ["run", "python", "files_server.py", "--stdio"],
    "cwd": ".",
    "allow_zero_tools": true,
    "tools": ["write_file", "edit_file", "list_directory", "run_command"],
    "description": "Focused file operations MCP server"
  },
  "coder-tools": {
    "transport": "stdio",
    "command": "uv",
    "args": ["run", "python", "coder_tools_server.py", "--stdio"],
    "cwd": ".",
    "description": "Coder tools MCP server for deep code generation and validation"
  }
}
